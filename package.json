{
  "name": "xsight",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "server:install": "npm --prefix server install",
    "server:dev": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "server:typecheck": "npm --prefix server run typecheck",
    "agentation:mcp": "agentation-mcp server",
    "agentation:doctor": "agentation-mcp doctor",
    "test:api": "npm --prefix server run test:api",
    "test:api:full": "npm --prefix server run test:api:full",
    "test:health": "node scripts/health-check.mjs",
    "test:activity": "npm --prefix server run activity",
    "test:all": "npm run test:health && npm run test:api",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test contracts/test/ParimutuelMarket.test.cjs"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "agentation": "^3.0.2",
    "agentation-mcp": "^1.2.0",
    "dotenv": "^17.4.2",
    "hardhat": "^2.28.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
