# XSight server environment
# Copy to server/.env and fill in. NEVER commit the real .env.

PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- Anthropic Claude ---
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OnchainOS / OKX DEX API ---
# Register at https://web3.okx.com/onchainos/dev-portal
# Connect wallet → create account → link email + phone → create project → generate API key
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_PROJECT_ID=

# --- Agentic Wallet (XSight project identity) ---
# AGENTIC_WALLET_ADDRESS must match the address derived from DEPLOYER_PRIVATE_KEY.
# Docs: https://web3.okx.com/onchainos/dev-docs/wallet/agentic-wallet
AGENTIC_WALLET_ADDRESS=

# Private key that signs swap transactions broadcast via X Layer RPC.
# WARNING: NEVER commit this. NEVER paste it in chat or share it anywhere.
# Use a dedicated wallet holding only funds you intend to trade with.
DEPLOYER_PRIVATE_KEY=

# X Layer RPC endpoint used for tx broadcast.
X_LAYER_RPC_URL=https://rpc.xlayer.tech

# --- CupHub Oracle ---
# Set after running: npm --prefix server run deploy:cup-oracle
CUP_ORACLE_V2_ADDRESS=
# Optional NFT-track proof badge. Set after running: npm --prefix server run deploy:fanpass-sbt
FANPASS_SBT_ADDRESS=
# Legacy V1 address can stay here for reference only; production writes use CUP_ORACLE_V2_ADDRESS.
CUP_ORACLE_ADDRESS=
CUP_ORACLE_CHALLENGE_WINDOW=3600
# --- Bonded oracle (HARDENING-PLAN Phase 2-6) ---
# Set after running: npm --prefix server run deploy:cup-oracle-v3
# When CUP_ORACLE_V3_ADDRESS is set the backend drives the bonded CupOracleV3 instead
# of CupOracleV2 — propose/challenge post a USDT bond, challenges route to the arbiter.
CUP_ORACLE_V3_ADDRESS=
CUP_ARBITER_ADDRESS=
# Deploy-time config for deploy:cup-oracle-v3 (defaults shown):
CUP_ORACLE_BOND_TOKEN=
CUP_ORACLE_BOND_AMOUNT=50000000
CUP_ORACLE_PROTOCOL_FEE_BPS=0
CUP_ORACLE_SAFETY_PERIOD=3600
CUP_ORACLE_TREASURY=
# Comma-separated arbiter panel + threshold (e.g. a 2-of-3).
CUP_ARBITER_SIGNERS=
CUP_ARBITER_THRESHOLD=2
# Enables operator endpoints that sign CupOracle settlement transactions.
# Keep false or protect with auth before exposing a public production server.
CUP_WRITE_API_ENABLED=false
# Optional admin key for settlement write endpoints. Required when NODE_ENV=production.
CUP_WRITE_API_KEY=
# Autonomous oracle resolver. WARNING: when true the server periodically sends real
# OKB-spending registerMatch/proposeResult/finalizeResult txs on CupOracleV2.
# Leave false unless a funded signer + CUP_WRITE_API_ENABLED=true are intentionally set.
CUP_RESOLVER_ENABLED=false
CUP_RESOLVER_INTERVAL_MS=300000

# --- ParimutuelMarket (prediction-market pools) ---
# X Layer stablecoin registry — public mainnet addresses, both 6-decimal ERC20s.
USDT_ADDRESS=0x1E4a5963aBFD975d8c9021ce480b42188849D41d
USDC_ADDRESS=0x74b7F16337b8972027F6196A17a631aC6dE26d22
# Which stablecoin a freshly deployed ParimutuelMarket settles in — set to one of
# the two addresses above before running: npm --prefix server run deploy:parimutuel
PARIMUTUEL_TOKEN_ADDRESS=
# Set after running deploy:parimutuel.
PARIMUTUEL_MARKET_ADDRESS=
# Receives the optional protocol fee. Defaults to AGENTIC_WALLET_ADDRESS when blank.
PARIMUTUEL_TREASURY=
# Protocol fee in basis points (integer 0..1000). 0 for the hackathon.
PARIMUTUEL_FEE_BPS=0
# Event indexer (DESIGN §4). Set PARIMUTUEL_DEPLOY_BLOCK to the market's deploy block so
# the indexer backfills the full history; leave 0 to index only from the current head.
PARIMUTUEL_DEPLOY_BLOCK=0
MARKET_INDEXER_INTERVAL_MS=30000
# eth_getLogs block span per poll. X Layer's public RPC caps this at 100.
MARKET_INDEXER_RANGE=90

# --- CupHub sports data adapters ---
# Production mode never falls back to seed data. Add free provider keys where available.
FOOTBALL_DATA_API_KEY=
THESPORTSDB_API_KEY=
THESPORTSDB_LEAGUE_ID=4429
ESPN_SOURCE_ENABLED=true
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard
# Development only. Ignored in NODE_ENV=production.
CUP_DEMO_MODE=false

# Optional hosted Postgres persistence for receipts/events/payment replay tracking.
DATABASE_URL=

# --- x402 payments ---
# Address that receives x402 USDT payments on X Layer (zero gas)
X402_PAYOUT_ADDRESS=
X402_NETWORK=xlayer-mainnet
X402_ASSET=USDT
# Required in production to verify ERC20 Transfer logs for paid endpoints.
X402_ASSET_ADDRESS=

# Development convenience only. Production still rejects dev-bypass.
ALLOW_DEV_BYPASS=false

# --- AI pundit wallet (Flow D) -------------------------------------------------
# The pundit's OWN wallet, separate from DEPLOYER_PRIVATE_KEY / AGENTIC_WALLET_ADDRESS
# so the operator that creates/settles markets never also stakes in them.
PUNDIT_PRIVATE_KEY=
PUNDIT_WALLET_ADDRESS=
# Stake per pick, in human units of the market settlement token (e.g. USDT).
PUNDIT_STAKE_AMOUNT=0.5

# --- AI pundit autonomous loop (Flow D) ---------------------------------------
# X (Twitter) API OAuth 1.0a user-context keys. Empty => the pundit never posts.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Autonomous staking cron. 'true' makes the pundit stake real OKB on a timer.
PUNDIT_AUTOSTAKE_ENABLED=false
PUNDIT_AUTOSTAKE_INTERVAL_MS=1800000

# --- BracketNFT (Plan 11) -----------------------------------------------------
# Set after deploying contracts/BracketNFT.sol (npm run deploy:bracket-nft).
BRACKET_NFT_ADDRESS=
BRACKET_NFT_BASE_URI=https://x-sight.vercel.app/bracket/
