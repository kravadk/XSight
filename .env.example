# XSight frontend environment — copy to .env.local, NEVER commit .env.local
# Blockaid API key goes in server/.env (not here — stays server-side)

# ── OKX DEX direct browser calls (optional) ────────────────────────────────
# Only needed if you want the frontend to call OKX DEX directly instead of
# going through the backend. Leave empty to use backend (recommended).
# https://web3.okx.com/onchainos/dev-portal
VITE_OKX_API_KEY=
VITE_OKX_SECRET_KEY=
VITE_OKX_PASSPHRASE=
VITE_OKX_PROJECT_ID=

# Agentation local annotation overlay (dev-only; production build does not render it).
# Keep disabled for screenshots/demo recording; set true only when annotating UI.
VITE_AGENTATION_ENABLED=false
VITE_AGENTATION_ENDPOINT=http://localhost:4747
