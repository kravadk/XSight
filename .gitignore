skills-lock.json

# Markdown is private-by-default — every .md added anywhere is auto-hidden from
# GitHub. Only the explicit allow-list below stays public:
#   - the root README.md  (the umbrella face)
#   - per-product READMEs in apps/*  (each mirrored to its own GitHub repo)
#   - packages/shared/config/docsContent.md  (source code — imported via Vite ?raw)
# To publish any other .md, add another `!/path/to/file.md` line below.
*.md
!/README.md
!/apps/xsight/README.md
!/apps/xcup/README.md
!/apps/hook/README.md
!/apps/hook/contracts/README.md
!/apps/hook/scripts/README.md
!/apps/hook/server/README.md
!/apps/xcup/server/README.md
!/apps/hook/contracts/SECURITY.md
!/apps/hook/docs/pitch-deck.md
!/apps/hook/docs/JUDGE-WALKTHROUGH.md
!/apps/hook/docs/INTEGRATION-GUIDE.md
!/apps/hook/docs/COMPETITIVE-ANALYSIS.md
!/apps/hook/CONTRIBUTING.md
!/packages/shared/config/docsContent.md

# Root-level docs/ tree — covers non-markdown artefacts too (screenshots, diagrams).
# Anchored to root so per-product apps/*/docs/ stays tracked (e.g. apps/xcup/docs/screenshots).
/docs/

# Ad-hoc smoke / diagnostic scripts (created during sessions, then deleted)
smoke-*.tmp.mjs
*.tmp.mjs
