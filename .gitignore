# Markdown is private-by-default — every .md added anywhere is auto-hidden from
# GitHub. Only the explicit allow-list below stays public:
#   - the root README.md  (the public face)
#   - src/config/docsContent.md  (source code — imported via Vite ?raw)
# To publish any other .md, add another `!/path/to/file.md` line below.
*.md
!/README.md
!/src/config/docsContent.md

# Whole docs/ tree — covers non-markdown artefacts too (screenshots, diagrams).
docs/

# Ad-hoc smoke / diagnostic scripts (created during sessions, then deleted)
smoke-*.tmp.mjs
*.tmp.mjs
