# X Cup environment variables (server-side slice).
# The umbrella server reads them at boot from server/.env. This file documents
# the X Cup-specific subset; see ../../server/.env.example for the full set.

# X Layer RPC + deployer (shared with the umbrella server)
X_LAYER_RPC_URL=https://rpc.xlayer.tech
DEPLOYER_PRIVATE_KEY=         # for hardhat / deploy scripts — NEVER commit

# Deployed contract addresses (mainnet, chain 196)
CUP_ORACLE_V3_ADDRESS=
ARBITER_MULTISIG_ADDRESS=
PARIMUTUEL_MARKET_ADDRESS=
FANPASS_SBT_ADDRESS=
BRACKET_NFT_ADDRESS=

# Indexer
PARIMUTUEL_DEPLOY_BLOCK=
DATABASE_URL=                 # Postgres for the parimutuel indexer

# Write-side feature flags (default false — keeps the server read-only)
CUP_WRITE_API_ENABLED=false
CUP_RESOLVER_ENABLED=false
CUP_WRITE_API_KEY=
